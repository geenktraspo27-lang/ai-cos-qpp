# Copy this file to .env and fill in your Supabase project's values.
# Found in: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (no VITE_ prefix — never bundled to the client). Used by
# api/generate-workflow.ts to call the Claude API. Set this in Vercel's
# Environment Variables, not in a .env file that ships anywhere.
ANTHROPIC_API_KEY=your-anthropic-api-key
